# Required: Network (testnet or mainnet)
NETWORK=testnet

# Optional: Walrus publisher's Sui address (tier 1 sender filter)
# Reduces noise by skipping BlobCertified events from other publishers.
# Without this, the indexer inspects all certified blobs 
WALRUS_PUBLISHER_SUI_ADDRESS=0x...

# Optional: REST API port (default: 3001)
PORT=3001
